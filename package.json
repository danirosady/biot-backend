{
  "name": "wiring-studio-backend",
  "version": "1.0.0",
  "description": "Backend server for Wiring Studio Visual IoT IDE",
  "main": "src/server/index.ts",
  "scripts": {
    "dev": "tsx --no-cache src/server/index.ts",
    "worker": "tsx --no-cache src/workers/startWorker.ts",
    "build": "tsc",
    "start": "node dist/server/index.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.15.0",
    "axios": "^1.11.0",
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "execa": "^8.0.0",
    "express": "^5.1.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^10.5.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.14",
    "prisma": "^6.15.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2"
  }
}
