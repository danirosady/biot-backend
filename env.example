# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bubuhaniot?schema=public
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# ThingsBoard Configuration
THINGSBOARD_BASE_URL=http://127.0.0.1:8080
THINGSBOARD_SYSADMIN_USERNAME=sysadmin@thingsboard.org
THINGSBOARD_SYSADMIN_PASSWORD=your_thingsboard_sysadmin_password
THINGSBOARD_TENANT_USERNAME=tenant@thingsboard.org
THINGSBOARD_TENANT_PASSWORD=your_thingsboard_tenant_password

# Encryption Key (32-byte base64)
ENCRYPTION_KEY=your_base64_32byte_encryption_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Server Configuration
PORT=4000
ALLOWED_ORIGIN=http://localhost:5173

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Arduino CLI Configuration
ARDUINO_CLI_PATH=C:\Program Files\Arduino IDE\resources\app\lib\backend\resources\arduino-cli.exe
ARDUINO_DEFAULT_FQBN=esp32:esp32:esp32
ARDUINO_TB_PUBSUBCLIENT_PATH=C:\Users\YourUser\Documents\Arduino\libraries\TBPubSubClient
FIRMWARE_STORAGE_PATH=./public/firmware
FIRMWARE_PUBLIC_BASE_URL=
OTA_DELIVERY_MODE=THINGSBOARD_UPLOAD
OTA_PACKAGE_TITLE=Firmware
TB_LEGACY_ASSIGN_FALLBACK=false

# JWT Configuration
JWT_SECRET=change_me_super_secret_jwt
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
